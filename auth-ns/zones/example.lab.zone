$TTL 86400
example.lab. IN SOA auth-ns.example.lab. admin.example.lab. (
    2024010101 ; serial
    3600       ; refresh
    900        ; retry
    604800     ; expire
    86400 )    ; minimum

example.lab.          IN NS  auth-ns.example.lab.
auth-ns.example.lab.  IN A   172.20.0.4

; actual records
example.lab.          IN A   172.20.0.4
www.example.lab.      IN A   172.20.0.4
mail.example.lab.     IN MX  10 172.20.0.4
